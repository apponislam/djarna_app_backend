NODE_ENV=development
IP=0.0.0.0
PORT=5000
MONGODB_URL=mongodb://<YOUR_MONGO_USER>:<YOUR_MONGO_PASS>@localhost:27017/<YOUR_DB_NAME>
BCRYPT_SALT_ROUNDS=12

CLIENT_URL=<YOUR_CLIENT_URL>
BACKEND_URL=<YOUR_BACKEND_URL>

# JWT 
JWT_ACCESS_SECRET=<YOUR_ACCESS_SECRET>
JWT_ACCESS_EXPIRE=30d
JWT_REFRESH_SECRET=<YOUR_REFRESH_SECRET>
JWT_REFRESH_EXPIRE=365d
JWT_PASSWORD_RESET_SECRET=<YOUR_PASSWORD_RESET_SECRET>

# Nodemailer
SMTP_HOST=<YOUR_SMTP_HOST>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<YOUR_SMTP_USER>
SMTP_PASS=<YOUR_SMTP_PASS>

# Admin  
SUPERADMINEMAIL=<YOUR_SUPERADMIN_EMAIL>
SUPERADMINPHONE=<YOUR_SUPERADMIN_PHONE>
SUPERADMINPASSWORD=<YOUR_SUPERADMIN_PASSWORD>

# Twilio_API
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>
TWILIO_PHONE_NUMBER=<YOUR_TWILIO_PHONE_NUMBER>
TWILIO_VERIFY_SERVICE_SID=<YOUR_TWILIO_VERIFY_SERVICE_SID>

# PAYMENT 
PAYDUNYA_MODE=sandbox # sandbox or live
PAYDUNYA_MASTER_KEY=<YOUR_PAYDUNYA_MASTER_KEY>
PAYDUNYA_PUBLIC_KEY=<YOUR_PAYDUNYA_PUBLIC_KEY>
PAYDUNYA_PRIVATE_KEY=<YOUR_PAYDUNYA_PRIVATE_KEY>
PAYDUNYA_TOKEN=<YOUR_PAYDUNYA_TOKEN>

